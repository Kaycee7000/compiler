---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Claim Your Portfolio | Sign Up">
<main class="flex min-h-screen flex-col items-center justify-center bg-slate-50 p-6 antialiased">

<div class="w-full max-w-md rounded-2xl bg-white p-8 shadow-xl border border-slate-200">
<div class="mb-8 text-center">
<h1 class="text-3xl font-black tracking-tight text-slate-900">Claim Your Portfolio</h1>
<p class="mt-2 text-slate-600">Create a secure account to save, edit, and manage your new live portfolio.</p>
</div>

<form id="signup-form" class="flex flex-col gap-5">
<div>
<label for="email" class="block text-sm font-bold text-slate-700 mb-1">Email Address</label>
<input
type="email"
id="email"
required
class="block w-full rounded-lg border border-slate-300 px-4 py-3 text-slate-900 focus:border-slate-950 focus:outline-none focus:ring-1 focus:ring-slate-950"
placeholder="you@example.com"
/>
</div>

<div>
<label for="password" class="block text-sm font-bold text-slate-700 mb-1">Password</label>
<input
type="password"
id="password"
required
minlength="6"
class="block w-full rounded-lg border border-slate-300 px-4 py-3 text-slate-900 focus:border-slate-950 focus:outline-none focus:ring-1 focus:ring-slate-950"
placeholder="••••••••"
/>
</div>

<p id="error-message" class="text-sm font-medium text-red-600 hidden"></p>

<button
type="submit"
id="submit-btn"
class="mt-2 w-full rounded-lg bg-slate-950 px-8 py-4 font-bold text-white transition hover:bg-slate-800 shadow-xl cursor-pointer"
>
Create Account & View Site
</button>
</form>
</div>
</main>

<script>
// Import the Supabase client library directly for use in the browser
import { createClient } from '@supabase/supabase-js';

// In Astro, client-side scripts require environment variables to be prefixed with PUBLIC_
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
const supabase = createClient(supabaseUrl, supabaseKey);

const form = document.getElementById('signup-form');
const emailInput = document.getElementById('email') as HTMLInputElement;
const passwordInput = document.getElementById('password') as HTMLInputElement;
const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
const errorMessage = document.getElementById('error-message');

// 1. Grab the student_id from the URL parameter
const urlParams = new URLSearchParams(window.location.search);
const studentId = urlParams.get('student_id');

// Security catch: If they visit this page directly without an ID, send them back to home
if (!studentId) {
window.location.href = '/';
}

form?.addEventListener('submit', async (e) => {
e.preventDefault();

// Reset the UI to a loading state
errorMessage?.classList.add('hidden');
submitBtn.textContent = 'Creating Account...';
submitBtn.disabled = true;

const email = emailInput.value;
const password = passwordInput.value;

try {
// 2 & 3. Let the user type in an email/password & Run supabase.auth.signUp()
const { data: authData, error: authError } = await supabase.auth.signUp({
email,
password,
});

if (authError) throw authError;

// 4. Once successful, link the portfolio row to their new user ID
if (authData.user) {
const { error: updateError } = await supabase
.from('portfolios')
.update({ user_id: authData.user.id })
.eq('student_id', studentId);

if (updateError) {
console.error("Supabase Update Error:", updateError);
throw new Error("Account created, but we couldn't link your portfolio. Please try again.");
}

// Redirect seamlessly to their live site!
window.location.href = '/dashboard';
}
} catch (err: any) {
// Handle any errors by displaying them to the user and resetting the button
if (errorMessage) {
errorMessage.textContent = err.message;
errorMessage.classList.remove('hidden');
}
submitBtn.textContent = 'Create Account & View Site';
submitBtn.disabled = false;
}
});
</script>
</Layout>

---
import Layout from '../layouts/Layout.astro';
---

<Layout title="OTILOF.COM">
  <main class="relative flex min-h-screen flex-col items-center justify-center bg-slate-50 p-6 text-center antialiased">

    <!-- Logo, top-left -->
    <div class="absolute top-6 left-6 sm:top-8 sm:left-8">
      <a href="/" class="inline-flex items-baseline text-2xl font-black tracking-tight text-slate-950">
        otilof<span class="text-amber-500">.</span>
      </a>
    </div>

    <!-- Top Navigation for Returning Users -->
    <div class="absolute top-6 right-6 sm:top-8 sm:right-8">
      <p class="text-sm text-slate-600 font-medium">
        Already have an account? 
        <a href="/signin" class="ml-2 inline-flex items-center justify-center rounded-lg border border-slate-200 bg-white px-4 py-2 font-bold text-slate-900 transition hover:border-slate-300 hover:bg-slate-50 shadow-sm">
          Sign In
        </a>
      </p>
    </div>

    <div class="inline-flex items-center rounded-full border border-amber-200 bg-amber-100 px-3 py-1 text-sm font-medium text-amber-900 mb-6">
       Resume to Portfolio Instantly
    </div>

    <h1 class="text-5xl font-black tracking-tight text-slate-900 sm:text-7xl">
      OTILOF.COM
    </h1>

    <p class="mt-6 max-w-2xl text-lg text-slate-600 sm:text-xl">
      Upload your resume to instantly generate a premium, globally hosted portfolio.
    </p>

    <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:justify-center">
      <!-- --- LEGACY (disabled): Microsoft OneDrive OAuth. Function body is commented
           out and its only caller (the button below) is disabled, so this tag is
           inert. Kept in place for quick rollback. --- -->
      <script is:inline>
        // function loginWithMicrosoft() {
        //   const clientId = "bc1e157e-9abe-4f5a-aaae-0c20c994c460";
        //   // We redirect to a new /callback page after they log in
        //   const redirectUri = window.location.origin + "/callback";
        //   const scopes = "Files.Read User.Read";
        //   const authUrl = `https://login.microsoftonline.com/common/oauth2/v2.0/authorize?client_id=${clientId}&response_type=token&redirect_uri=${redirectUri}&scope=${scopes}`;
        //   window.location.href = authUrl;
        // }
      </script>

      <!-- NEW: resume upload replaces the OneDrive connect flow -->
      <script is:inline>
        const RESUME_API_ENDPOINT = "https://api.otilof.com/api/generate-portfolio";

        function triggerResumeUpload() {
          document.getElementById("resume-input").click();
        }

        async function handleResumeSelected(input) {
          const file = input.files[0];
          if (!file) return;

          const button = document.getElementById("upload-button");
          const status = document.getElementById("upload-status");
          const originalLabel = button.textContent;

          button.disabled = true;
          button.textContent = "Generating your portfolio...";
          status.textContent = "";

          const formData = new FormData();
          formData.append("resume", file);

          try {
            const res = await fetch(RESUME_API_ENDPOINT, {
              method: "POST",
              body: formData,
            });

            if (!res.ok) {
              const err = await res.json().catch(() => ({}));
              throw new Error(err.detail || `Request failed (${res.status})`);
            }

            const data = await res.json();
            window.location.href = `/signup?student_id=${data.student_id}`;
          } catch (err) {
            status.textContent = err.message || "Couldn't generate your portfolio. Please try again.";
            button.disabled = false;
            button.textContent = originalLabel;
            input.value = "";
          }
        }
      </script>

      <input
        type="file"
        id="resume-input"
        accept=".pdf,.docx,.txt,.md"
        class="hidden"
        onchange="handleResumeSelected(this)"
      />

      <button
        id="upload-button"
        onclick="triggerResumeUpload()"
        class="rounded-full bg-slate-950 px-8 py-4 font-bold text-white transition hover:bg-slate-800 shadow-xl cursor-pointer"
      >
        Upload Your Resume
      </button>

      <a href="/demo-student" class="rounded-full border-2 border-slate-200 bg-white px-8 py-4 font-bold text-slate-900 transition hover:border-slate-300">
        View Demo Profile
      </a>
    </div>

    <p id="upload-status" class="mt-4 text-sm text-red-600"></p>

    <!-- Featurebase SDK: loads the Messenger (live chat + help center) -->
    <script is:inline>
      !(function(e,t){const a="featurebase-sdk";function n(){if(!t.getElementById(a)){var e=t.createElement("script");(e.id=a),(e.src="https://do.featurebase.app/js/sdk.js"),t.getElementsByTagName("script")[0].parentNode.insertBefore(e,t.getElementsByTagName("script")[0])}}"function"!=typeof e.Featurebase&&(e.Featurebase=function(){(e.Featurebase.q=e.Featurebase.q||[]).push(arguments)}),"complete"===t.readyState||"interactive"===t.readyState?n():t.addEventListener("DOMContentLoaded",n)})(window,document);

      Featurebase("boot", {
        appId: "YOUR_APP_ID", // TODO: replace with your Featurebase App ID (Settings → Developers → Installation)
        hideDefaultLauncher: true, // we use our own button below instead of Featurebase's floating launcher
      });
    </script>

    <!-- Support button, bottom-right -->
    <button
      type="button"
      onclick="Featurebase('show')"
      aria-label="Contact support"
      title="Contact support"
      class="fixed bottom-6 right-6 sm:bottom-8 sm:right-8 z-50 inline-flex h-14 w-14 items-center justify-center rounded-full bg-slate-950 text-white shadow-xl transition hover:bg-slate-800 hover:scale-105"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
      </svg>
    </button>
  </main>
</Layout>

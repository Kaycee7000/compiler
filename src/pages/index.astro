---
import Layout from "../layouts/layout.astro";
---
<Layout>
  <main class="relative overflow-hidden">
    <div
      class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_top,_rgba(59,130,246,0.15),_transparent_60%)]"
    >
    </div>
    <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-6">
      <a href="/" class="text-lg font-bold tracking-tight text-slate-950">
        PortfolioAI
      </a>
      <div class="hidden items-center gap-8 text-sm font-medium text-slate-600 sm:flex">
        <a href="#how" class="hover:text-slate-950">How it works</a>
        <a href="#pricing" class="hover:text-slate-950">Pricing</a>
        <a href="/demo-student" class="hover:text-slate-950">Demo</a>
      </div>
    </nav>
    <section class="mx-auto max-w-5xl px-6 pb-24 pt-16 text-center sm:pt-24">
      <span
        class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white/60 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-slate-700 shadow-sm backdrop-blur"
      >
        <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
        Only $9.99 · One-time
      </span>
      <h1
        class="mt-6 text-5xl font-black tracking-tight text-slate-950 sm:text-7xl"
      >
        Your schoolwork,<br />
        as a <span class="bg-gradient-to-r from-blue-600 to-indigo-600 bg-clip-text text-transparent">premium portfolio</span>.
      </h1>
      <p class="mt-6 mx-auto max-w-2xl text-lg text-slate-600 sm:text-xl">
        Connect your .edu OneDrive and let AI analyze your coursework to instantly generate a premium, globally hosted portfolio.
      </p>
      <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:justify-center">
        <button
          class="rounded-lg bg-slate-950 px-8 py-4 font-bold text-white shadow-xl transition hover:bg-slate-800"
        >
          Connect OneDrive
        </button>
        {/* Change this URL to whatever student_id you put in your Supabase database to test! */}
        <a
          href="/demo-student"
          class="rounded-lg border-2 border-slate-200 bg-white px-8 py-4 font-bold text-slate-900 transition hover:border-slate-300"
        >
          View Demo Profile
        </a>
      </div>
      <p class="mt-6 text-sm text-slate-500">
        Hosted on a global CDN · Custom subdomain included · Cancel anytime
      </p>
    </section>
    <section id="how" class="mx-auto max-w-6xl px-6 pb-24">
      <div class="grid gap-6 sm:grid-cols-3">
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <div class="text-sm font-bold text-blue-600">01</div>
          <h3 class="mt-2 text-lg font-bold text-slate-950">Connect .edu OneDrive</h3>
          <p class="mt-2 text-sm text-slate-600">
            Sign in with your school Microsoft account. Read-only, secure, revoke anytime.
          </p>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <div class="text-sm font-bold text-blue-600">02</div>
          <h3 class="mt-2 text-lg font-bold text-slate-950">AI analyzes coursework</h3>
          <p class="mt-2 text-sm text-slate-600">
            Essays, projects, and assignments become polished case studies with summaries and tags.
          </p>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <div class="text-sm font-bold text-blue-600">03</div>
          <h3 class="mt-2 text-lg font-bold text-slate-950">Ship your portfolio</h3>
          <p class="mt-2 text-sm text-slate-600">
            Globally hosted, blazing fast, and yours forever on a shareable link.
          </p>
        </div>
      </div>
    </section>
    <section id="pricing" class="mx-auto max-w-3xl px-6 pb-32">
      <div
        class="rounded-3xl border border-slate-200 bg-gradient-to-b from-white to-slate-50 p-10 text-center shadow-xl"
      >
        <div class="text-sm font-semibold uppercase tracking-wider text-slate-500">
          One-time payment
        </div>
        <div class="mt-3 flex items-baseline justify-center gap-1">
          <span class="text-6xl font-black text-slate-950">$9.99</span>
        </div>
        <p class="mt-3 text-slate-600">
          Everything included. No subscriptions. No surprises.
        </p>
        <button
          class="mt-8 rounded-lg bg-slate-950 px-8 py-4 font-bold text-white shadow-xl transition hover:bg-slate-800"
        >
          Get my portfolio
        </button>
      </div>
    </section>
    <footer class="border-t border-slate-200 py-8 text-center text-sm text-slate-500">
      © {new Date().getFullYear()} PortfolioAI · Built for students
    </footer>
  </main>
</Layout>

---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sign In | Access Your Portfolio">
<main class="flex min-h-screen flex-col items-center justify-center bg-slate-50 p-6 antialiased">

<div class="w-full max-w-md rounded-2xl bg-white p-8 shadow-xl border border-slate-200">
  <div class="mb-8 text-center">
    <h1 class="text-3xl font-black tracking-tight text-slate-900">Welcome Back</h1>
    <p class="mt-2 text-slate-600">Sign in to manage and edit your live portfolio.</p>
  </div>

  <form id="signin-form" class="flex flex-col gap-5">
    <div>
      <label for="email" class="block text-sm font-bold text-slate-700 mb-1">Email Address</label>
      <input
        type="email"
        id="email"
        required
        class="block w-full rounded-lg border border-slate-300 px-4 py-3 text-slate-900 focus:border-slate-950 focus:outline-none focus:ring-1 focus:ring-slate-950"
        placeholder="you@example.com"
      />
    </div>

    <div>
      <label for="password" class="block text-sm font-bold text-slate-700 mb-1">Password</label>
      <input
        type="password"
        id="password"
        required
        class="block w-full rounded-lg border border-slate-300 px-4 py-3 text-slate-900 focus:border-slate-950 focus:outline-none focus:ring-1 focus:ring-slate-950"
        placeholder="••••••••"
      />
    </div>

    <p id="error-message" class="text-sm font-medium text-red-600 hidden"></p>

    <button
      type="submit"
      id="submit-btn"
      class="mt-2 w-full rounded-lg bg-slate-950 px-8 py-4 font-bold text-white transition hover:bg-slate-800 shadow-xl cursor-pointer"
    >
      Sign In
    </button>
  </form>
  
  <p class="mt-6 text-center text-sm text-slate-600">
    Don't have an account? <a href="/signup" class="font-bold text-slate-950 hover:underline">Claim your portfolio</a>
  </p>
</div>
</main>

<script>
import { createClient } from '@supabase/supabase-js';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
const supabase = createClient(supabaseUrl, supabaseKey);

// --- THE HASH CATCHER ---
// If a user clicks an email link, gets bounced from the dashboard by SSR, 
// they land here with the token still in the URL. Let's catch it!
if (window.location.hash.includes('access_token')) {
  supabase.auth.getSession().then(({ data }) => {
    if (data.session) {
      document.cookie = `sb-access-token=${data.session.access_token}; path=/; SameSite=Lax; Secure`;
      document.cookie = `sb-refresh-token=${data.session.refresh_token}; path=/; SameSite=Lax; Secure`;
      
      // Send them back to the dashboard, keeping the hash so the "Account Verified" banner shows up!
      window.location.href = '/dashboard' + window.location.hash; 
    }
  });
}
// ------------------------

const form = document.getElementById('signin-form');
const emailInput = document.getElementById('email') as HTMLInputElement;
const passwordInput = document.getElementById('password') as HTMLInputElement;
const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
const errorMessage = document.getElementById('error-message');

form?.addEventListener('submit', async (e) => {
  e.preventDefault();
  
  errorMessage?.classList.add('hidden');
  submitBtn.textContent = 'Signing In...';
  submitBtn.disabled = true;

  try {
    const { data, error } = await supabase.auth.signInWithPassword({
      email: emailInput.value,
      password: passwordInput.value,
    });

    if (error) throw error;

    if (data.session) {
      // Save the tokens as cookies so Astro SSR can read them on subsequent page requests
      document.cookie = `sb-access-token=${data.session.access_token}; path=/; SameSite=Lax; Secure`;
      document.cookie = `sb-refresh-token=${data.session.refresh_token}; path=/; SameSite=Lax; Secure`;
      
      // Redirect seamlessly to their dashboard
      window.location.href = '/dashboard';
    }
  } catch (err: any) {
    if (errorMessage) {
      errorMessage.textContent = err.message || "Invalid login credentials.";
      errorMessage.classList.remove('hidden');
    }
    submitBtn.textContent = 'Sign In';
    submitBtn.disabled = false;
  }
});
</script>
</Layout>

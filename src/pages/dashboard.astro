---
import Layout from '../layouts/Layout.astro';

// Note: Fetch the user's session and portfolio row here via Supabase SSR
// Placeholder variables for the UI logic:
const studentId = "julian-vance"; // Replace with dynamic portfolio.student_id
const isPremium = false;          // Replace with dynamic portfolio.is_premium
const tokensRemaining = 0;        // Replace with dynamic portfolio.tokens_remaining (Default 0 for free, 5 for premium)
---

<Layout title="Dashboard | Manage Account">
  <main class="max-w-6xl mx-auto p-6 md:p-12">
    
    <!-- Account Verified Banner -->
    <div id="verification-banner" class="hidden bg-emerald-50 text-emerald-800 border border-emerald-200 p-4 rounded-xl mb-8 font-medium flex items-center gap-3">
      <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
      Account Verified Successfully!
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <!-- Left Column: Portfolio Preview -->
      <div class="lg:col-span-2 space-y-8">
         <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200">
            <h2 class="text-2xl font-black tracking-tight text-slate-900 mb-2">Your Live Portfolio</h2>
            <div class="flex gap-2 mt-4">
                <!-- Dynamically inject the student ID into the URL -->
                <input type="text" readonly value={`https://portloo.com/${studentId}`} class="w-full p-3 bg-slate-50 border border-slate-200 rounded-lg text-slate-600 focus:outline-none" />
                <button class="bg-slate-900 text-white px-6 font-bold rounded-lg hover:bg-slate-800 transition">Copy</button>
            </div>
         </div>

         <div class="bg-slate-100 rounded-2xl shadow-inner border border-slate-200 h-[600px] overflow-hidden relative">
            <!-- Dynamically inject the iframe source -->
            <iframe src={`/${studentId}`} class="w-full h-full border-0 pointer-events-none"></iframe>
         </div>
      </div>

      <!-- Right Column: Controls & Paywall -->
      <div class="space-y-8">
         
         <!-- Tokens & Regeneration -->
         <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200">
            <h2 class="text-xl font-bold text-slate-900">AI Regenerate</h2>
            <div class="mt-4 flex items-center justify-between text-sm text-slate-600">
                <span>Tokens remaining</span>
                <!-- Dynamically render the token count -->
                <span class="bg-slate-100 px-3 py-1 rounded-full font-black text-slate-900">{tokensRemaining} / 5</span>
            </div>
            
            <!-- Disable button and style as locked if 0 tokens -->
            <button 
              disabled={tokensRemaining === 0}
              class={`w-full mt-6 py-3 rounded-xl font-bold transition border ${tokensRemaining > 0 ? 'bg-slate-900 text-white hover:bg-slate-800 border-slate-900' : 'bg-slate-50 text-slate-400 cursor-not-allowed border-slate-200'}`}
            >
                {tokensRemaining > 0 ? 'Regenerate Design' : 'Upgrade to Regenerate'}
            </button>
         </div>

         <!-- Premium Paywall: Only show if the user is NOT premium -->
         { !isPremium && (
             <div class="bg-gradient-to-br from-indigo-600 to-purple-700 p-8 rounded-2xl shadow-xl text-white relative overflow-hidden">
                <div class="relative z-10">
                    <h2 class="text-2xl font-black">Unlock Premium</h2>
                    <ul class="mt-6 space-y-3 text-indigo-100 font-medium">
                       <li class="flex gap-2"><span>✓</span> Remove Portloo watermark</li>
                       <li class="flex gap-2"><span>✓</span> Custom domain linking</li>
                       <!-- Updated to reflect the 5 token limit accurately -->
                       <li class="flex gap-2"><span>✓</span> Unlock 5 AI Theme Regenerations</li>
                    </ul>
                    <button class="w-full bg-white text-indigo-700 mt-8 py-4 rounded-xl font-black shadow-lg hover:scale-[1.02] transition-transform cursor-pointer">
                        Upgrade - $9.99
                    </button>
                </div>
             </div>
         )}

      </div>
    </div>
  </main>

  <script>
    if (window.location.hash.includes('type=signup') || window.location.hash.includes('access_token')) {
        const banner = document.getElementById('verification-banner');
        if (banner) banner.classList.remove('hidden');
        
        // Clean the URL hash so the banner doesn't persist on refresh
        window.history.replaceState(null, '', window.location.pathname + window.location.search);
    }
  </script>
</Layout>

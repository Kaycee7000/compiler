---
// src/pages/[student_id].astro
import Layout from '../layouts/Layout.astro';
// 1. Import the specific Router component!
import { PortfolioRouter } from '../components/IndustryTemplates';

const { student_id } = Astro.params;

if (student_id === 'favicon.ico' || student_id === 'robots.txt') {
  return new Response(null, { status: 404 });
}

const runtimeEnv = Astro.locals?.runtime?.env || import.meta.env;
const supabaseUrl = runtimeEnv?.SUPABASE_URL;
const supabaseKey = runtimeEnv?.SUPABASE_ANON_KEY;

if (!supabaseUrl || !supabaseKey) {
  throw new Error("SERVER ERROR: Supabase environment variables are missing from Cloudflare.");
}

const response = await fetch(`${supabaseUrl}/rest/v1/portfolios?student_id=eq.${student_id}&select=*`, {
  headers: {
    'apikey': supabaseKey,
    'Authorization': `Bearer ${supabaseKey}`
  }
});

if (!response.ok) {
  throw new Error(`DATABASE ERROR: ${response.status} ${response.statusText}`);
}

const dbResult = await response.json();

if (!dbResult || dbResult.length === 0) {
  return new Response(`404: Portfolio for '${student_id}' not found. Did you run the Supabase INSERT script?`, { 
    status: 404,
    headers: { "Content-Type": "text/html" }
  });
}

const studentRecord = dbResult[0];
const data = studentRecord.portfolio_data; 
const cssTheme = studentRecord.theme_css; 
const templateId = studentRecord.template_id;

// EXPLICITLY EXTRACT PREMIUM STATUS HERE
const isPremium = studentRecord.is_premium;
---

<Layout title={`${data.profile.name} — Professional Portfolio`} description={data.profile.headline}>
    
    <style set:html={cssTheme}></style>

    <main class="relative min-h-screen">
        {/* 2. Call the static router and pass it the data! */}
        <PortfolioRouter templateId={templateId} data={data} client:load />
        
        {/* THE WATERMARK OVERLAY: Only renders if is_premium is FALSE */}
        { !isPremium && (
          <div class="fixed inset-0 z-[9999] pointer-events-none select-none overflow-hidden flex flex-col justify-between p-12 opacity-[0.04]">
            <div class="flex justify-between w-full text-4xl font-black tracking-widest text-slate-900 uppercase transform -rotate-12 whitespace-nowrap">
              <span>otilof.com</span>
              <span>otilof.com</span>
              <span>Potilof.com</span>
            </div>
            <div class="flex justify-around w-full text-4xl font-black tracking-widest text-slate-900 uppercase transform -rotate-12 whitespace-nowrap">
              <span>otilof.com</span>
              <span>Potilof.com</span>
              <span>otilof.com</span>
            </div>
            <div class="flex justify-between w-full text-4xl font-black tracking-widest text-slate-900 uppercase transform -rotate-12 whitespace-nowrap">
              <span>otilof.com</span>
              <span>otilof.com</span>
              <span>otilof.com</span>
            </div>
            <div class="flex justify-around w-full text-4xl font-black tracking-widest text-slate-900 uppercase transform -rotate-12 whitespace-nowrap">
              <span>otilof.com</span>
              <span>otilof.com</span>
              <span>otilof.com</span>
            </div>
          </div>
        )}
    </main>
</Layout>
